{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BTP site extraction dossier",
  "type": "object",
  "required": ["meta", "brand", "company", "sections", "testimonials", "images"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["sourceUrl", "domain", "extractedAt", "pagesCrawled", "toolVersion", "warnings"],
      "properties": {
        "sourceUrl": { "type": "string" },
        "domain": { "type": "string" },
        "extractedAt": { "type": "string" },
        "pagesCrawled": { "type": "array", "items": { "type": "string" } },
        "toolVersion": { "type": "string" },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "brand": {
      "type": "object",
      "required": ["logo", "palette", "typography"],
      "properties": {
        "logo": {
          "type": "object",
          "required": ["candidates", "best", "favicon"],
          "properties": {
            "candidates": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["src", "confidence", "location", "width", "height", "altText"],
                "properties": {
                  "src": { "type": "string" },
                  "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                  "location": { "type": "string", "enum": ["header", "footer", "favicon", "other"] },
                  "width": { "type": "number" },
                  "height": { "type": "number" },
                  "altText": { "type": ["string", "null"] }
                }
              }
            },
            "best": { "type": ["string", "null"] },
            "favicon": { "type": ["string", "null"] }
          }
        },
        "palette": {
          "type": "object",
          "required": ["method", "swatches"],
          "properties": {
            "method": { "type": "string", "enum": ["vibrant-from-logo", "vibrant-from-screenshots", "css-computed", "mixed"] },
            "swatches": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["hex", "role", "source", "population"],
                "properties": {
                  "hex": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
                  "role": { "type": "string", "enum": ["dominant", "primary", "secondary", "accent", "background", "text"] },
                  "source": { "type": "string", "enum": ["logo", "hero-screenshot", "css"] },
                  "population": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              }
            }
          }
        },
        "typography": {
          "type": "object",
          "required": ["detectedFontFamilies", "headingFontStack", "bodyFontStack"],
          "properties": {
            "detectedFontFamilies": { "type": "array", "items": { "type": "string" } },
            "headingFontStack": { "type": ["string", "null"] },
            "bodyFontStack": { "type": ["string", "null"] }
          }
        }
      }
    },
    "company": {
      "type": "object",
      "required": ["name", "tagline", "metier", "yearsExperience", "certifications", "serviceArea", "contact", "keyFigures"],
      "properties": {
        "name": { "type": ["string", "null"] },
        "tagline": { "type": ["string", "null"] },
        "metier": { "type": "array", "items": { "type": "string" } },
        "yearsExperience": { "type": ["string", "null"] },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "serviceArea": { "type": ["string", "null"] },
        "keyFigures": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "value", "source"],
            "properties": {
              "label": { "type": ["string", "null"] },
              "value": { "type": "number" },
              "source": { "type": "string", "enum": ["digit-reel", "data-attribute"] }
            }
          }
        },
        "contact": {
          "type": "object",
          "required": ["phone", "email", "address", "siret", "socialLinks"],
          "properties": {
            "phone": { "type": "array", "items": { "type": "string" } },
            "email": { "type": "array", "items": { "type": "string" } },
            "address": { "type": ["string", "null"] },
            "siret": { "type": ["string", "null"] },
            "socialLinks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["platform", "url"],
                "properties": {
                  "platform": { "type": "string" },
                  "url": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "sourcePage", "headline", "body", "items", "images", "rawTextBlocks"],
        "properties": {
          "id": { "type": "string", "enum": ["hero", "services", "a-propos", "realisations", "avis", "contact", "footer", "other"] },
          "sourcePage": { "type": "string" },
          "domSelector": { "type": ["string", "null"] },
          "screenshot": { "type": ["string", "null"] },
          "headline": { "type": ["string", "null"] },
          "body": { "type": "array", "items": { "type": "string" } },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["title", "description", "images"],
              "properties": {
                "title": { "type": "string" },
                "description": { "type": ["string", "null"] },
                "images": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "images": { "type": "array", "items": { "type": "string" } },
          "rawTextBlocks": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "testimonials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["author", "sourcePlatform", "rating", "quote", "date", "extractionMethod"],
        "properties": {
          "author": { "type": ["string", "null"] },
          "sourcePlatform": { "type": "string", "enum": ["google", "site-native", "facebook", "unknown"] },
          "rating": { "type": ["number", "null"] },
          "quote": { "type": "string" },
          "date": { "type": ["string", "null"] },
          "extractionMethod": { "type": "string", "enum": ["dom-text", "ocr-flagged-for-review"] },
          "screenshot": { "type": ["string", "null"] }
        }
      }
    },
    "images": {
      "type": "object",
      "required": ["manifest"],
      "properties": {
        "manifest": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "originalUrl", "width", "height", "hash", "usedInSections", "altText"],
            "properties": {
              "file": { "type": "string" },
              "originalUrl": { "type": "string" },
              "width": { "type": "number" },
              "height": { "type": "number" },
              "hash": { "type": "string" },
              "usedInSections": { "type": "array", "items": { "type": "string" } },
              "altText": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  }
}
